generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  profileImage String?

  provider   AuthProvider @default(GOOGLE)
  providerId String
  role       UserRole     @default(STUDENT)

  teacherProfile TeacherProfile?

  studentBookings Booking[] @relation("StudentBookings")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
}

model TeacherProfile {
  id     String @id @default(cuid())
  userId String @unique

  timezone String @default("Asia/Seoul")

  headline        String?
  bio             String?
  profileImageUrl String?
  hourlyRate      Int?
  status          TeacherStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  teacherLanguages   TeacherLanguage[]
  teacherSpecialties TeacherSpecialty[]

  availabilities  Availability[] @relation("TeacherAvailabilities")
  teacherBookings Booking[]      @relation("TeacherBookings")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id   String @id @default(cuid())
  code String @unique
  name String @unique

  teacherLanguages TeacherLanguage[]
}

model TeacherLanguage {
  teacherId  String
  languageId String

  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  language Language       @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([teacherId, languageId])
}

model Specialty {
  id   String @id @default(cuid())
  code String @unique
  name String @unique

  teacherSpecialties TeacherSpecialty[]
}

model TeacherSpecialty {
  teacherId   String
  specialtyId String

  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  specialty Specialty      @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([teacherId, specialtyId])
}

model Availability {
  id String @id @default(cuid())

  teacherId String
  teacher   TeacherProfile @relation("TeacherAvailabilities", fields: [teacherId], references: [id], onDelete: Cascade)

  startAt DateTime
  endAt   DateTime
  isOpen  Boolean  @default(false)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, startAt])
  @@index([teacherId, isOpen, startAt])
  @@index([startAt])
}

model Booking {
  id String @id @default(cuid())

  teacherId String
  teacher   TeacherProfile @relation("TeacherBookings", fields: [teacherId], references: [id])

  studentId String
  student   User   @relation("StudentBookings", fields: [studentId], references: [id])

  availabilityId String
  availability   Availability @relation(fields: [availabilityId], references: [id])

  lessonStartAt DateTime
  lessonEndAt   DateTime

  status           BookingStatus @default(PENDING_PAYMENT)
  paymentExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Availability로 예약 조회
  @@index([availabilityId])
  // Student My Bookings
  @@index([studentId, lessonStartAt])
  // Teacher Dashboard
  @@index([teacherId, lessonStartAt])
  // 만료 예약 정리
  @@index([status, paymentExpiresAt])
}

enum AuthProvider {
  GOOGLE
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum TeacherStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}
