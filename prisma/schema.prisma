generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  name         String?
  profileImage String?

  provider   AuthProvider @default(GOOGLE)
  providerId String
  role       UserRole     @default(STUDENT)

  teacherProfile TeacherProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
}

model TeacherProfile {
  id     String @id @default(cuid())
  userId String @unique

  headline   String?
  bio        String?
  profileImageUrl String?
  hourlyRate Int?
  status     TeacherStatus @default(PENDING)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  teacherLanguages   TeacherLanguage[]
  teacherSpecialties TeacherSpecialty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Language {
  id   String @id @default(cuid())
  code String @unique
  name String @unique

  teacherLanguages TeacherLanguage[]
}

model TeacherLanguage {
  teacherId  String
  languageId String

  teacher  TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  language Language       @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([teacherId, languageId])
}


model Specialty {
  id   String @id @default(cuid())
  code String @unique
  name String @unique

  teacherSpecialties TeacherSpecialty[]
}

model TeacherSpecialty {
  teacherId   String
  specialtyId String

  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  specialty Specialty      @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([teacherId, specialtyId])
}

enum AuthProvider {
  GOOGLE
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum TeacherStatus {
  PENDING
  APPROVED
  REJECTED
}